# Server-only Supabase credentials. Never expose the service-role key in client.js.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=YOUR_SERVER_ONLY_SECRET_OR_SERVICE_ROLE_KEY
SUPABASE_ROOM_TABLE=jesters_grid_rooms

# Optional web-push configuration. Stable generated keys are used when omitted.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:notifications@example.com

# Local server port.
PORT=3000
